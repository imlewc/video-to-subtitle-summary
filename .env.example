# ASR 后端选择：faster-whisper（默认）或 volcengine
ASR_BACKEND=faster-whisper

# TikHub API - 用于获取抖音/小红书/B站视频信息和下载地址（YouTube 不需要）
# 申请教程: docs/tikhub-setup.md
TIKHUB_TOKEN=your_tikhub_api_token

# faster-whisper - 本地语音转写运行时参数（ASR_BACKEND=faster-whisper 时生效）
# 安装教程: docs/faster-whisper-setup.md
FW_MODEL_SIZE=small
FW_DEVICE=auto
FW_COMPUTE_TYPE=

# 火山引擎 VC - 云端字幕转写参数（ASR_BACKEND=volcengine 时生效）
# 安装教程: docs/bytedance-vc-setup.md
BYTEDANCE_VC_TOKEN=your_bytedance_vc_token
BYTEDANCE_VC_APPID=your_bytedance_vc_appid
